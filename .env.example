# AWS + Aurora DSQL — set in .env.local (and Vercel project env vars).
# Local dev works with these; without them the API routes cannot reach DSQL.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Aurora DSQL cluster (from `node scripts/dsql-create.mjs`)
PGHOST=cluster-id.dsql.us-east-1.on.aws
PGUSER=admin
PGDATABASE=postgres
PGPORT=5432

# Optional: site URL for OG metadata (set to your Vercel domain after deploy)
NEXT_PUBLIC_SITE_URL=https://agentledger.vercel.app
